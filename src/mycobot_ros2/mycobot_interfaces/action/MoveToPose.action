# Goal
geometry_msgs/PoseStamped target_pose
float64 velocity_scale        # 0.0-1.0
float64 acceleration_scale    # 0.0-1.0
string planning_pipeline      # "" = use default (ompl)
---
# Result
bool success
string message
geometry_msgs/PoseStamped achieved_pose
---
# Feedback
string state                  # "planning" | "executing"
